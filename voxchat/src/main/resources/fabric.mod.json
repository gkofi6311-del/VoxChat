{
  "schemaVersion": 1,
  "id": "voxchat",
  "version": "${version}",

  "name": "VoxChat",
  "description": "Press V to record your voice and insert it into the chat input. Supports English and German via Vosk offline STT.",
  "authors": [
    "Francis"
  ],
  "contact": {
    "sources": "https://github.com/YOUR_USERNAME/voxchat"
  },
  "license": "MIT",

  "environment": "client",

  "entrypoints": {
    "main":   ["com.francis.voxchat.VoxChatMod"],
    "client": ["com.francis.voxchat.VoxChatClient"]
  },

  "mixins": [
    "voxchat.client.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.15.0",
    "fabric-api":   "*",
    "minecraft":    "~1.21.1",
    "java":         ">=21"
  },

  "suggests": {}
}
